# Cloudflare R2 Configuration — used for IMAGE UPLOADS only
R2_ENDPOINT=https://REPLACE_WITH_YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=REPLACE_WITH_YOUR_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_SECRET_ACCESS_KEY
R2_BUCKET_NAME=chiraa-portfolio
R2_PUBLIC_URL=https://REPLACE_WITH_YOUR_R2_PUBLIC_URL

# Supabase Configuration — used for storing all data (projects, blogs, videos)
SUPABASE_URL=https://REPLACE_WITH_YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_ANON_KEY

# Server
PORT=5000
NODE_ENV=development
